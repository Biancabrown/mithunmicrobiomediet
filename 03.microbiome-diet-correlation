# 2. Procrustes analysis (Figure 1)

## Two-axis Procrustes / PROTEST

```{r protest-2axis}
microbe_ord <- cmdscale(microbiome_asv_dist_common, k = 2, eig = TRUE)
diet_ord    <- cmdscale(diet_asv_dist_common,       k = 2, eig = TRUE)

protest_res <- vegan::protest(
  X            = microbe_ord$points,
  Y            = diet_ord$points,
  permutations = 999
)
protest_res
```

## Full-dimension Procrustes (positive eigenvalues only)

```{r protest-fulldim}
microbe_ord_full <- cmdscale(
  microbiome_asv_dist_common,
  k   = nrow(as.matrix(microbiome_asv_dist_common)) - 1,
  eig = TRUE
)

diet_ord_full <- cmdscale(
  diet_asv_dist_common,
  k   = nrow(as.matrix(diet_asv_dist_common)) - 1,
  eig = TRUE
)

m_eig <- microbe_ord_full$eig[1:ncol(microbe_ord_full$points)]
d_eig <- diet_ord_full$eig[1:ncol(diet_ord_full$points)]

m_pos <- microbe_ord_full$points[, m_eig > 0]
d_pos <- diet_ord_full$points[, d_eig > 0]

protest_full <- vegan::protest(X = m_pos, Y = d_pos, permutations = 999)
protest_full
```

## Controlling for Season

We test congruence after (a) residualizing each axis on Season, and (b)
restricting permutations to within-season blocks.

```{r protest-season-controls}
season <- factor(meta_common$Season)

# (a) Residualize each PCoA axis on Season, then PROTEST
residualize <- function(X, f) {
  apply(X, 2, function(col) residuals(lm(col ~ f)))
}

m_resid <- residualize(m_pos, season)
d_resid <- residualize(d_pos, season)

protest_resid <- vegan::protest(X = m_resid, Y = d_resid, permutations = 999)
protest_resid

# (b) Permute within Season blocks
ctrl <- how(blocks = season, nperm = 999)
protest_within <- vegan::protest(X = m_pos, Y = d_pos, permutations = ctrl)
protest_within
```

## Procrustes plot (residual arrows by season)

```{r protest-plot Figure 5C}
pro <- vegan::protest(
