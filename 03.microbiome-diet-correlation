# 1. Match samples between datasets

```{r match-samples}
micro_samples <- attr(microbiome_asv_dist, "Labels")
diet_samples  <- attr(diet_asv_dist,       "Labels")

common_samples <- intersect(micro_samples, diet_samples)

# Subset both distance matrices to the common samples, in matching order
microbiome_asv_dist_common <- as.dist(
  as.matrix(microbiome_asv_dist)[common_samples, common_samples]
)

diet_asv_dist_common <- as.dist(
  as.matrix(diet_asv_dist)[common_samples, common_samples]
)

# Aligned metadata
meta_common <- physeq_mithun.meta[
  match(common_samples, physeq_mithun.meta$SampleID), ,
  drop = FALSE
]

meta_common$Season <- factor(
  meta_common$Season,
  levels = c("Spring", "Summer", "Autumn", "Winter")
)

# Sanity check
stopifnot(identical(
  attr(microbiome_asv_dist_common, "Labels"),
  attr(diet_asv_dist_common,       "Labels")
))
```

