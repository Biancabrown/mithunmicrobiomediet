# 3. Mantel tests (Figure 2)

## Overall Mantel correlation

```{r mantel-overall}
mantel_res <- vegan::mantel(
  microbiome_asv_dist_common,
  diet_asv_dist_common,
  method       = "spearman",
  permutations = 999
)
mantel_res
```

## Family-level Mantel (with explicit sample alignment)

```{r mantel-family}
m1 <- as.matrix(dist_mithun_fam)
m2 <- as.matrix(dist_diet)

common_fam <- intersect(rownames(m1), rownames(m2))

d1_fam <- as.dist(m1[common_fam, common_fam])
d2_fam <- as.dist(m2[common_fam, common_fam])

vegan::mantel(xdis = d1_fam, ydis = d2_fam,
              method = "spearman", permutations = 999)
```

## Within-season Mantel tests

```{r mantel-within-season}
mantel_by_season <- list()

for (seas in levels(meta_common$Season)) {

  season_samples <- meta_common$SampleID[meta_common$Season == seas]

  if (length(season_samples) < 4) {
    message("Too few samples for ", seas)
    next
  }

  micro_s <- as.dist(
    as.matrix(microbiome_asv_dist_common)[season_samples, season_samples]
  )
  diet_s  <- as.dist(
    as.matrix(diet_asv_dist_common)[season_samples, season_samples]
  )

  res <- vegan::mantel(
    micro_s, diet_s,
    method       = "spearman",
    permutations = 999
  )

  mantel_by_season[[seas]] <- res
  message("\n--- ", seas, " ---")
  print(res)
}
```

## Partial Mantel controlling for Season

```{r mantel-partial}
season_dist <- dist(as.numeric(meta_common$Season))

vegan::mantel.partial(
  microbiome_asv_dist_common,
  diet_asv_dist_common,
  season_dist,
  method       = "spearman",
  permutations = 999
)
```

