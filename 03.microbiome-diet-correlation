# 6. Alpha-diversity correlations (Figure 5)

## Merge diet and microbiome alpha diversity

```{r alpha-merge}
alpha_diversity.$SampleID <- rownames(alpha_diversity.)

merged_cor <- merge(
  diet.physeq_diet.rich,
  alpha_diversity.,
  by   = "SampleID",
  all.y = TRUE
)

# Disambiguate columns from the two tables
colnames(merged_cor) <- gsub("\\.x$", "_diet",       colnames(merged_cor))
colnames(merged_cor) <- gsub("\\.y$", "_microbiome", colnames(merged_cor))
```

## Linear models: Shannon and Observed

```{r alpha-models}
# Shannon: does diet diversity predict microbiome diversity, controlling for Season?
mod_shannon <- lm(Shannon_diet ~ Shannon_microbiome + Season_microbiome,
                  data = merged_cor)
summary(mod_shannon)
anova(mod_shannon)

# Observed
mod_observed <- lm(Observed_diet ~ Observed_microbiome + Season_microbiome,
                   data = merged_cor)
summary(mod_observed)
anova(mod_observed)

# Type-III ANOVAs with Season interactions
car::Anova(
  lm(Shannon_microbiome  ~ Shannon_diet  * Season_diet, data = merged_cor),
  type = 3
)
car::Anova(
  lm(Observed_microbiome ~ Observed_diet * Season_diet, data = merged_cor),
  type = 3
)

# Combined additive models
anova(lm(Observed_microbiome ~ Observed_diet + Season_microbiome,
         data = merged_cor))
anova(lm(Shannon_microbiome  ~ Shannon_diet  + Season_microbiome,
         data = merged_cor))
```

## Spearman correlations

```{r alpha-correlations}
# Overall
cor.test(merged_cor$Observed_diet, merged_cor$Observed_microbiome,
         method = "spearman")
cor.test(merged_cor$Shannon_microbiome, merged_cor$Shannon_diet,
         method = "spearman")

# Season-stratified Spearman correlations (Observed)
cor.test(~ Observed_diet + Observed_microbiome,
         data   = subset(merged_cor, Season_microbiome == "Summer"),
         method = "spearman")

cor.test(~ Observed_diet + Observed_microbiome,
         data   = subset(merged_cor, Season_microbiome == "Winter"),
         method = "spearman")

# Season-stratified linear models (Shannon)
seasons <- c("Spring", "Summer", "Autumn", "Winter")
for (s in seasons) {
  cat("\n--- Shannon, ", s, " ---\n", sep = "")
  print(anova(lm(Shannon_diet ~ Shannon_microbiome,
                 data = subset(merged_cor, Season_microbiome == s))))
}

```

