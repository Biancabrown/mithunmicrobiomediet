# 5. Envfit overlay (Figure 5C)

Fit individual diet and microbiome taxa onto the microbiome PCoA, and
overlay significant taxa as arrows.

## Setup: paired distance matrices and CLR matrices

```{r envfit-setup}
microbiome_dist <- dist_mithun_fam
diet_dist       <- physeq_diet.clr.ind.dist

microbiome_clr_obj <- physeq_mithun.fix.family
diet_clr_obj       <- physeq_diet.clr

# Common samples
common_samples <- intersect(
  attr(microbiome_dist, "Labels"),
  attr(diet_dist,       "Labels")
)

microbiome_dist_common <- as.dist(
  as.matrix(microbiome_dist)[common_samples, common_samples]
)

# Metadata in matching order
meta_common <- physeq_mithun.meta[
  match(common_samples, physeq_mithun.meta$SampleID), ,
  drop = FALSE
]
stopifnot(all(meta_common$SampleID == common_samples))

meta_common$Season <- factor(
  meta_common$Season,
  levels = c("Spring", "Summer", "Autumn", "Winter")
)
```

## Microbiome PCoA scores

```{r envfit-pcoa}
microbe_ord <- cmdscale(microbiome_dist_common, k = 2, eig = TRUE)

microbe_scores <- as.data.frame(microbe_ord$points)
colnames(microbe_scores) <- c("Axis1", "Axis2")
microbe_scores$SampleID  <- common_samples
microbe_scores$Season    <- meta_common$Season
microbe_scores$Ind       <- meta_common$Ind
```

## Aligned CLR matrices for diet and microbiome

```{r envfit-clr}
diet_clr_mat <- as(otu_table(diet_clr_obj), "matrix")
if (taxa_are_rows(diet_clr_obj)) diet_clr_mat <- t(diet_clr_mat)
diet_clr_common <- diet_clr_mat[common_samples, , drop = FALSE]

microbe_clr_mat <- as(otu_table(microbiome_clr_obj), "matrix")
if (taxa_are_rows(microbiome_clr_obj)) microbe_clr_mat <- t(microbe_clr_mat)
microbe_clr_common <- microbe_clr_mat[common_samples, , drop = FALSE]

stopifnot(all(rownames(diet_clr_common)    == common_samples))
stopifnot(all(rownames(microbe_clr_common) == common_samples))
```

## Envfit: project diet and microbiome taxa onto microbiome PCoA

```{r envfit-fit}
envfit_diet <- envfit(
  microbe_ord$points,
  diet_clr_common,
  permutations = 999
)

envfit_microbe <- envfit(
  microbe_ord$points,
  microbe_clr_common,
  permutations = 999
)

# Tidy outputs: diet
diet_vectors <- as.data.frame(scores(envfit_diet, display = "vectors"))
diet_vectors$taxa <- rownames(diet_vectors)
diet_vectors$pval <- envfit_diet$vectors$pvals
diet_vectors$r2   <- envfit_diet$vectors$r
colnames(diet_vectors)[1:2] <- c("Axis1", "Axis2")

diet_vectors_sig <- diet_vectors %>%
  filter(pval < 0.07) %>%
  mutate(vec_len = sqrt(Axis1^2 + Axis2^2)) %>%
  arrange(desc(vec_len)) %>%
  slice_head(n = 10)

# Tidy outputs: microbiome
microbe_vectors <- as.data.frame(scores(envfit_microbe, display = "vectors"))
microbe_vectors$taxa <- rownames(microbe_vectors)
microbe_vectors$pval <- envfit_microbe$vectors$pvals
microbe_vectors$r2   <- envfit_microbe$vectors$r
colnames(microbe_vectors)[1:2] <- c("Axis1", "Axis2")

microbe_vectors_sig <- microbe_vectors %>%
  filter(pval < 0.07) %>%
  mutate(vec_len = sqrt(Axis1^2 + Axis2^2)) %>%
  arrange(desc(vec_len)) %>%
  slice_head(n = 10)

# Optional supplementary table
# diet_vectors %>% write_csv("TableS15_envfit_diet.csv")
```

